#!/usr/bin/env python3
"""trck — a deterministic, single-file, in-repo issue tracker.

Bookkeeping is scripted; prose is hand-authored, so the tracker can't drift.
Status = the folder a markdown file lives in; other metadata lives in index.jsonl;
SUMMARY.md is generated. Python standard library only. See README.md.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import urllib.error
import urllib.request
from datetime import date
from pathlib import Path

__version__ = "0.1.1"
DEFAULT_UPDATE_REPO = "leonkacowicz/trck"
SELF_PATH = Path(__file__).resolve()  # the running engine file; tests may override

SLUG_RE = re.compile(r"^[a-z0-9][a-z0-9-]*$")
FILENAME_RE = re.compile(r"^(\d{3,})-([a-z0-9][a-z0-9-]*)\.md$")


def die(msg: str):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def today() -> str:
    return date.today().isoformat()


def slugify(text: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")


# --------------------------------------------------------------------------- #
# config + discovery
# --------------------------------------------------------------------------- #
DEFAULT_CONFIG = {
    "update": {"repo": DEFAULT_UPDATE_REPO, "channel": "stable"},
    "statuses": [
        {"name": "backlog", "role": "initial"},
        {"name": "ongoing"},
        {"name": "done", "role": "terminal"},
    ],
    "aliases": {"start": "ongoing", "done": "done"},
    "priorities": ["high", "medium", "low"],
    "kinds": ["task", "epic"],
    "resolutions": ["superseded", "wontfix", "duplicate"],
}


def load_config(tracker_dir: Path) -> dict:
    """Merge trck.json (if any) over DEFAULT_CONFIG. Top-level keys override;
    the nested 'update' dict is merged key-by-key."""
    cfg = json.loads(json.dumps(DEFAULT_CONFIG))  # deep copy
    path = Path(tracker_dir) / "trck.json"
    if path.exists():
        try:
            user = json.loads(path.read_text() or "{}")
        except json.JSONDecodeError as e:
            die(f"{path}: invalid JSON ({e})")
        for k, v in user.items():
            if k == "update" and isinstance(v, dict):
                cfg["update"].update(v)
            else:
                cfg[k] = v
    return cfg


def status_names(cfg: dict) -> list[str]:
    return [s["name"] for s in cfg["statuses"]]


def status_role(cfg: dict, name: str) -> str | None:
    for s in cfg["statuses"]:
        if s["name"] == name:
            return s.get("role")
    return None


def initial_status(cfg: dict) -> str:
    for s in cfg["statuses"]:
        if s.get("role") == "initial":
            return s["name"]
    return cfg["statuses"][0]["name"]


def terminal_statuses(cfg: dict) -> list[str]:
    return [s["name"] for s in cfg["statuses"] if s.get("role") == "terminal"]


def is_terminal(cfg: dict, name: str) -> bool:
    return status_role(cfg, name) == "terminal"


def resolve_alias(cfg: dict, verb: str) -> str | None:
    return cfg.get("aliases", {}).get(verb)


def find_tracker(start: Path, required: bool = True) -> Path | None:
    """Walk up from `start` to the folder containing trck.json (or a child holding it).
    With `required=False`, return None instead of dying when nothing is found."""
    start = Path(start).resolve()
    cur = start
    while True:
        if (cur / "trck.json").exists():
            return cur
        hits = sorted(cur.glob("*/trck.json"))
        if len(hits) == 1:
            return hits[0].parent.resolve()
        if len(hits) > 1:
            die(f"ambiguous tracker under {cur} ({len(hits)} found); pass --dir")
        if cur.parent == cur:
            if required:
                die("no tracker found here; run `trck init`")
            return None
        cur = cur.parent


def resolve_tracker_dir(dir_opt, env=None, required: bool = True) -> Path | None:
    """Resolution order: --dir > TRCK_DIR > vendored self-location > walk up from cwd.
    With `required=False`, return None instead of dying when nothing resolves."""
    env = os.environ if env is None else env
    if dir_opt:
        p = Path(dir_opt).resolve()
        if not (p / "trck.json").exists():
            if required:
                die(f"{p} is not a tracker (no trck.json)")
            return None
        return p
    if env.get("TRCK_DIR"):
        return resolve_tracker_dir(env["TRCK_DIR"], env={}, required=required)
    if (SELF_PATH.parent / "trck.json").exists():
        return SELF_PATH.parent
    return find_tracker(Path.cwd(), required=required)


# --------------------------------------------------------------------------- #
# context + index I/O
# --------------------------------------------------------------------------- #
CANON_KEYS = [
    "id", "slug", "title", "kind", "status", "priority", "parent",
    "milestone", "depends_on", "spec", "created", "started", "closed",
    "resolution",
]


class Ctx:
    """Resolved invocation context: the tracker dir and its merged config."""
    def __init__(self, dir: Path, cfg: dict):
        self.dir = Path(dir)
        self.cfg = cfg

    @property
    def index_path(self) -> Path:
        return self.dir / "index.jsonl"


def build_ctx(args, required: bool = True) -> Ctx | None:
    d = resolve_tracker_dir(getattr(args, "dir", None), required=required)
    if d is None:
        return None
    return Ctx(d, load_config(d))


def filename(row: dict) -> str:
    return f"{row['id']:03d}-{row['slug']}.md"


def rel_link(row: dict) -> str:
    return f"{row['status']}/{filename(row)}"


def issue_path(ctx: Ctx, row: dict) -> Path:
    return ctx.dir / row["status"] / filename(row)


def load_index(ctx: Ctx) -> list[dict]:
    if not ctx.index_path.exists():
        return []
    rows = []
    for n, line in enumerate(ctx.index_path.read_text().splitlines(), 1):
        line = line.strip()
        if not line:
            continue
        try:
            row = json.loads(line)
        except json.JSONDecodeError as e:
            die(f"index.jsonl line {n}: invalid JSON ({e})")
        row.setdefault("depends_on", [])
        rows.append(row)
    return rows


def save_index(ctx: Ctx, rows: list[dict]) -> None:
    rows = sorted(rows, key=lambda r: r["id"])
    lines = []
    for r in rows:
        ordered = {k: r.get(k, [] if k == "depends_on" else None) for k in CANON_KEYS}
        for k in sorted(r):  # preserve unknown keys, appended in stable order
            if k not in ordered:
                ordered[k] = r[k]
        lines.append(json.dumps(ordered, ensure_ascii=False))
    ctx.index_path.write_text("\n".join(lines) + ("\n" if lines else ""))


def get_row(rows: list[dict], issue_id: int) -> dict:
    for r in rows:
        if r["id"] == issue_id:
            return r
    die(f"no issue with id {issue_id}")


def next_id(ctx: Ctx) -> int:
    ids = {r["id"] for r in load_index(ctx)}
    for name in status_names(ctx.cfg):
        d = ctx.dir / name
        if d.is_dir():
            for p in d.glob("*.md"):
                m = FILENAME_RE.match(p.name)
                if m:
                    ids.add(int(m.group(1)))
    return (max(ids) + 1) if ids else 1


# --------------------------------------------------------------------------- #
# filesystem scan + validation
# --------------------------------------------------------------------------- #
def scan_files(ctx: Ctx) -> dict:
    """Map id -> (status_folder, slug, filename) for every issue markdown on disk."""
    found = {}
    for name in status_names(ctx.cfg):
        d = ctx.dir / name
        if not d.is_dir():
            continue
        for p in sorted(d.glob("*.md")):
            m = FILENAME_RE.match(p.name)
            if not m:
                continue
            iid = int(m.group(1))
            if iid in found:
                die(f"duplicate issue id {iid:03d} on disk: {found[iid][0]} and {name}")
            found[iid] = (name, m.group(2), p.name)
    return found


def validate(ctx: Ctx) -> tuple[list[str], list[str]]:
    errors, warnings = [], []
    rows = load_index(ctx)
    files = scan_files(ctx)
    by_id = {r["id"]: r for r in rows}
    names = set(status_names(ctx.cfg))
    prios = set(ctx.cfg["priorities"])
    kinds = set(ctx.cfg["kinds"])
    resolutions = set(ctx.cfg["resolutions"])

    for iid, r in by_id.items():
        if iid not in files:
            errors.append(f"#{iid:03d} in index but no markdown file on disk")
            continue
        folder, slug, fname = files[iid]
        if r.get("status") != folder:
            errors.append(f"#{iid:03d} index status '{r.get('status')}' != folder '{folder}'")
        if r.get("slug") != slug:
            errors.append(f"#{iid:03d} index slug '{r.get('slug')}' != filename slug '{slug}'")
        if fname != filename(r):
            errors.append(f"#{iid:03d} filename '{fname}' != expected '{filename(r)}'")
        if not r.get("slug") or not SLUG_RE.match(r.get("slug", "")):
            errors.append(f"#{iid:03d} bad slug '{r.get('slug')}'")
        if r.get("status") not in names:
            errors.append(f"#{iid:03d} unknown status '{r.get('status')}'")
        if r.get("kind") not in kinds:
            errors.append(f"#{iid:03d} bad kind '{r.get('kind')}'")
        if r.get("priority") not in prios:
            errors.append(f"#{iid:03d} bad priority '{r.get('priority')}'")
        res = r.get("resolution")
        if res not in (None, *resolutions):
            errors.append(f"#{iid:03d} bad resolution '{res}'")
    for iid in files:
        if iid not in by_id:
            errors.append(f"#{iid:03d} markdown file on disk but no index row")

    for r in rows:
        parent = r.get("parent")
        if parent is not None:
            if parent not in by_id:
                errors.append(f"#{r['id']:03d} parent #{parent:03d} does not exist")
        for dep in r.get("depends_on", []):
            if dep not in by_id:
                errors.append(f"#{r['id']:03d} depends_on #{dep:03d} which does not exist")

    for r in rows:  # parent cycles
        seen, cur = set(), r
        while cur and cur.get("parent") is not None:
            if cur["parent"] in seen:
                errors.append(f"#{r['id']:03d} is in a parent cycle")
                break
            seen.add(cur["parent"])
            cur = by_id.get(cur["parent"])

    children = {}
    for r in rows:
        if r.get("parent") is not None and r["parent"] in by_id:
            children.setdefault(r["parent"], []).append(r)
    term = lambda name: is_terminal(ctx.cfg, name)
    for pid, kids in children.items():
        parent_row = by_id[pid]
        if all(term(k["status"]) for k in kids) and not term(parent_row["status"]):
            warnings.append(
                f"#{pid:03d} has all children terminal but is still "
                f"{parent_row['status']} (run `trck done {pid}` or `trck mv …`)"
            )
    for r in rows:
        p = r.get("parent")
        if p is not None and p in by_id and term(by_id[p]["status"]) and not term(r["status"]):
            warnings.append(f"#{r['id']:03d} is {r['status']} but its parent #{p:03d} is terminal")
        if term(r["status"]):
            for dep in r.get("depends_on", []):
                if dep in by_id and not term(by_id[dep]["status"]):
                    warnings.append(f"#{r['id']:03d} is terminal but depends on non-terminal #{dep:03d}")
    return errors, warnings


# --------------------------------------------------------------------------- #
# tree rendering helpers (used by SUMMARY, tree, deps)
# --------------------------------------------------------------------------- #
STATUS_ICON = {"terminal": "✅", "initial": "☐", None: "⏳"}


def status_icon(ctx: Ctx, name: str) -> str:
    return STATUS_ICON.get(status_role(ctx.cfg, name), "⏳")


def node_label(ctx: Ctx, r: dict) -> str:
    ms = f"{r['milestone']} — " if r.get("milestone") else ""
    tag = " ·epic·" if r.get("kind") == "epic" else ""
    return f"#{r['id']:03d} {status_icon(ctx, r['status'])} {ms}{r['title']}{tag}"


def walk_tree(nodes, children_fn, label_fn, prefix="", seen=frozenset()):
    nodes = list(nodes)
    for i, node in enumerate(nodes):
        last = i == len(nodes) - 1
        connector = "└─ " if last else "├─ "
        cycle = node["id"] in seen
        print(prefix + connector + label_fn(node) + (" (cycle)" if cycle else ""))
        if cycle:
            continue
        ext = "   " if last else "│  "
        walk_tree(children_fn(node), children_fn, label_fn, prefix + ext, seen | {node["id"]})


# --------------------------------------------------------------------------- #
# SUMMARY.md generation
# --------------------------------------------------------------------------- #
def generate_summary(ctx: Ctx) -> str:
    rows = load_index(ctx)
    children = {}
    for r in rows:
        if r.get("parent") is not None:
            children.setdefault(r["parent"], []).append(r)
    names = status_names(ctx.cfg)
    term = lambda n: is_terminal(ctx.cfg, n)

    counts = {n: 0 for n in names}
    for r in rows:
        counts[r["status"]] = counts.get(r["status"], 0) + 1
    total = len(rows)

    out = []
    out.append("<!-- GENERATED by `trck summary` — do not hand-edit. -->")
    out.append("# Issues Summary")
    out.append("")
    out.append("## Counts")
    out.append("")
    out.append("| State | Count |")
    out.append("|---|---:|")
    for n in names:
        out.append(f"| {n} | {counts[n]} |")
    out.append(f"| **total** | **{total}** |")
    out.append("")

    parents = sorted([r for r in rows if r["id"] in children], key=lambda r: r["id"])
    if parents:
        out.append("## Hierarchies")
        out.append("")
        for parent in parents:
            kids = sorted(children.get(parent["id"], []),
                          key=lambda r: (r.get("milestone") or "", r["id"]))
            ndone = sum(1 for k in kids if term(k["status"]))
            pct = round(100 * ndone / len(kids)) if kids else 0
            out.append(
                f"### [#{parent['id']:03d} {parent['title']}]({rel_link(parent)}) — "
                f"{pct}% ({ndone}/{len(kids)}) · _{parent['priority']}_ · {parent['status']}"
            )
            if parent.get("spec"):
                out.append(f"Spec: [`{parent['spec']}`](../{parent['spec']})")
            if kids:
                strip = " · ".join(
                    f"{(k.get('milestone') or '?')} {status_icon(ctx, k['status'])}" for k in kids
                )
                out.append("")
                out.append(strip)
                out.append("")
                for k in kids:
                    box = "x" if term(k["status"]) else " "
                    ms = f"{k['milestone']} — " if k.get("milestone") else ""
                    tail = "" if term(k["status"]) else f" _({k['status']})_"
                    out.append(f"- [{box}] [#{k['id']:03d} {ms}{k['title']}]({rel_link(k)}){tail}")
            out.append("")

    def standalone(status):
        return sorted(
            [r for r in rows if r["status"] == status and r["id"] not in children
             and r.get("parent") is None],
            key=lambda r: r["id"],
        )

    for status in names:
        items = standalone(status)
        out.append(f"## {status.capitalize()}")
        out.append("")
        if not items:
            out.append("_none_")
        for r in items:
            extra = ""
            if r.get("resolution"):
                extra += f" · _{r['resolution']}_"
            if is_terminal(ctx.cfg, status) and r.get("closed"):
                extra += f" (closed {r['closed']})"
            out.append(f"- [#{r['id']:03d} {r['title']}]({rel_link(r)}) — _{r['priority']}_{extra}")
        out.append("")

    return "\n".join(out).rstrip() + "\n"


def write_summary(ctx: Ctx) -> None:
    (ctx.dir / "SUMMARY.md").write_text(generate_summary(ctx))


# --------------------------------------------------------------------------- #
# finalize: persist + regenerate + validate after every mutation
# --------------------------------------------------------------------------- #
def finalize(ctx: Ctx, rows: list[dict]) -> None:
    save_index(ctx, rows)
    write_summary(ctx)
    errors, warnings = validate(ctx)
    for w in warnings:
        print(f"warning: {w}", file=sys.stderr)
    if errors:
        print("\nINCONSISTENCIES after this operation:", file=sys.stderr)
        for e in errors:
            print(f"  error: {e}", file=sys.stderr)
        print("the tracker is now inconsistent — fix before committing.", file=sys.stderr)


# --------------------------------------------------------------------------- #
# networking seam + version helpers (used by `update`)
# --------------------------------------------------------------------------- #
def fetch_url(url: str, accept: str | None = None) -> str:
    headers = {"User-Agent": "trck"}
    if accept:
        headers["Accept"] = accept
    req = urllib.request.Request(url, headers=headers)
    with urllib.request.urlopen(req, timeout=30) as resp:
        return resp.read().decode("utf-8")


def parse_version(s: str) -> tuple:
    s = s.lstrip("vV").strip()
    parts = []
    for chunk in s.split("."):
        m = re.match(r"\d+", chunk)
        parts.append(int(m.group()) if m else 0)
    return tuple(parts)


def latest_release(repo: str) -> tuple[str, str]:
    url = f"https://api.github.com/repos/{repo}/releases/latest"
    data = json.loads(fetch_url(url, accept="application/vnd.github+json"))
    return data["tag_name"], data.get("body", "")


