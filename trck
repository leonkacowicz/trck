def parse_ids(spec):
    if not spec:
        return []
    return [int(p.strip()) for p in spec.split(",") if p.strip()]


def move_issue(ctx: Ctx, row: Issue, new_status: str) -> None:
    """Move the file between status folders and stamp dates from roles."""
    if new_status not in status_names(ctx.cfg):
        die(f"unknown status '{new_status}' (configured: {', '.join(status_names(ctx.cfg))})")
    old_status = row.status
    old = issue_path(ctx, row)
    row.status = new_status
    new = issue_path(ctx, row)
    if old.resolve() != new.resolve():
        new.parent.mkdir(parents=True, exist_ok=True)
        if not old.exists():
            die(f"file missing for #{row.id:03d}: {old}")
        shutil.move(str(old), str(new))

    init = initial_status(ctx.cfg)
    if old_status == init and new_status != init and not row.started:
        row.started = today()
    if is_terminal(ctx.cfg, new_status):
        if not row.closed:
            row.closed = today()
    else:
        row.closed = None
        row.resolution = None


def cmd_new(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    by_id = {r.id: r for r in rows}
    iid = next_id(ctx)
    slug = args.slug or slugify(args.title)
    if not SLUG_RE.match(slug):
        die(f"computed slug '{slug}' is invalid; pass --slug")
    priority = args.priority or ctx.cfg["priorities"][0]
    if priority not in ctx.cfg["priorities"]:
        die(f"bad priority '{priority}' (configured: {', '.join(ctx.cfg['priorities'])})")
    rawpoints = getattr(args, "points", None)
    points = DEFAULT_POINTS if rawpoints is None else int(str(rawpoints))
    if points < 0:
        die(f"bad points {points} (must be a non-negative integer)")
    kind = args.kind or ctx.cfg["kinds"][0]
    if kind not in ctx.cfg["kinds"]:
        die(f"bad kind '{kind}' (configured: {', '.join(ctx.cfg['kinds'])})")
    parent = args.parent
    if parent is not None and parent not in by_id:
        die(f"--parent #{parent:03d} does not exist")
    deps = parse_ids(args.depends)
    for dep in deps:
        if dep not in by_id:
            die(f"--depends references #{dep:03d} which does not exist")
    row = Issue(
        id=iid, slug=slug, title=args.title, kind=kind,
        status=initial_status(ctx.cfg), priority=priority, points=points,
        parent=parent, depends_on=deps, spec=args.spec, created=today(),
    )
    path = issue_path(ctx, row)
    if path.exists():
        die(f"{path} already exists")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(TEMPLATE.format(title=args.title))
    rows.append(row)
    finalize(ctx, rows)
    print(path)


def cmd_mv(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    row = get_row(rows, args.id)
    resolution = getattr(args, "resolution", None)
    if resolution is not None:
        if not is_terminal(ctx.cfg, args.status):
            die(f"--resolution is only valid when moving to a terminal status")
        if resolution not in ctx.cfg["resolutions"]:
            die(f"bad resolution '{resolution}' (configured: {', '.join(ctx.cfg['resolutions'])})")
    move_issue(ctx, row, args.status)
    if resolution is not None:
        row.resolution = resolution
    finalize(ctx, rows)
    print(issue_path(ctx, row))


def cmd_set(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    by_id = {r.id: r for r in rows}
    row = get_row(rows, args.id)
    if args.priority:
        if args.priority not in ctx.cfg["priorities"]:
            die(f"bad priority '{args.priority}'")
        row.priority = args.priority
    if getattr(args, "points", None) is not None:
        if args.points < 0:
            die(f"bad points {args.points} (must be a non-negative integer)")
        if row.id in parent_ids(rows):
            die(f"#{row.id:03d} has children; points is derived from them, not set")
        row.points = args.points
    if args.parent is not None:
        if args.parent == "none":
            row.parent = None
        else:
            pid = int(args.parent)
            if pid not in by_id:
                die(f"--parent #{pid:03d} must be an existing issue")
            row.parent = pid
    if args.spec is not None:
        row.spec = None if args.spec == "none" else args.spec
    if args.kind:
        if args.kind not in ctx.cfg["kinds"]:
            die(f"bad kind '{args.kind}'")
        row.kind = args.kind
    old = issue_path(ctx, row)
    if args.slug:
        if not SLUG_RE.match(args.slug):
            die(f"invalid slug '{args.slug}'")
        row.slug = args.slug
    if args.title:
        row.title = args.title
    new = issue_path(ctx, row)
    if old.resolve() != new.resolve():
        shutil.move(str(old), str(new))
    if args.title:
        text = new.read_text()
        text = re.sub(r"^# .*$", f"# {args.title}", text, count=1, flags=re.MULTILINE)
        new.write_text(text)
    finalize(ctx, rows)
    print(f"#{row.id:03d} updated")


def cmd_label(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    row = get_row(rows, args.id)
    labels = list(row.labels)
    for lab in (args.add or []):
        if lab and lab not in labels:
            labels.append(lab)
    for lab in (args.remove or []):
        if lab in labels:
            labels.remove(lab)
    row.labels = sorted(labels)
    finalize(ctx, rows)
    print(f"#{row.id:03d} labels={row.labels}")


def cmd_dep(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    by_id = {r.id: r for r in rows}
    row = get_row(rows, args.id)
    deps = list(row.depends_on)
    if args.add is not None:
        if args.add not in by_id:
            die(f"#{args.add:03d} does not exist")
        if args.add == row.id:
            die(f"#{row.id:03d} cannot depend on itself")
        if dep_would_cycle(by_id, row.id, args.add):
            die(f"#{row.id:03d} -> #{args.add:03d} would create a dependency cycle")
        if args.add not in deps:
            deps.append(args.add)
    if args.remove is not None and args.remove in deps:
        deps.remove(args.remove)
    row.depends_on = sorted(deps)
    finalize(ctx, rows)
    print(f"#{row.id:03d} depends_on={row.depends_on}")


def cmd_show(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    row = get_row(rows, args.id)
    full = row.to_dict()
    keys = CANON_KEYS + sorted(row.extra)
    if row.id in parent_ids(rows):
        keys = [k for k in keys if k != "points"]  # derived from leaves, not an input here
    if getattr(args, "json", False):
        print(json.dumps({k: full.get(k) for k in keys}, ensure_ascii=False, indent=2))
    else:
        w = max(len(k) for k in keys)
        for k in keys:
            v = full.get(k)
            if v is None or v == []:
                continue  # skip empty fields in the human view
            print(f"{paint(f'{k:>{w}}', 'dim')}  {v}")
    print("\n--- body ---\n")
    print(issue_path(ctx, row).read_text())


def cmd_list(args) -> None:
    ctx = build_ctx(args)
    rows = sorted(load_index(ctx), key=lambda r: r.id)
    by_id = {r.id: r for r in rows}

    keep_st, drop_st = parse_status_filter(args.status)
    match = (getattr(args, "match", None) or "").lower()
    only_blocked = getattr(args, "blocked", False)
    only_orphan = getattr(args, "orphan", False)

    def keep(r):
        return ((not keep_st or r.status in keep_st)
                and r.status not in drop_st
                and (not args.kind or r.kind == args.kind)
                and (not args.priority or r.priority == args.priority)
                and (not getattr(args, "label", None) or args.label in (r.labels or []))
                and (args.parent is None or r.parent == args.parent)
                and (not match or match in r.title.lower())
                and (not only_blocked or is_blocked(ctx.cfg, r, by_id))
                and (not only_orphan or r.parent is None))

    rows = [r for r in rows if keep(r)]

    sort = getattr(args, "sort", None)
    sort_keys = {
        "priority": lambda r: (priority_rank(ctx.cfg, r.priority), r.id),
        "points": lambda r: (-r.points, r.id),
        "created": lambda r: (r.created or "", r.id),
        "id": lambda r: r.id,
    }
    if sort in sort_keys:
        rows.sort(key=sort_keys[sort])

    print_rows(ctx, rows)


def print_rows(ctx: Ctx, rows: list[Issue]) -> None:
    """Render issues as aligned one-line summaries (shared by `list` and `ready`)."""
    if not rows:
        return
    sw = max(len(r.status) for r in rows)
    pw = max(len(r.priority) for r in rows)
    for r in rows:
        tags = []
        if r.kind == "epic":
            tags.append("EPIC")
        if r.parent:
            tags.append(f"↳{r.parent:03d}")
        tags.extend(r.labels or [])
        tagstr = paint(" [" + " ".join(tags) + "]", "dim") if tags else ""
        codes = status_codes(ctx.cfg, r.status)
        icon = paint(status_icon(ctx, r.status), *codes)
        iid = paint(f"#{r.id:03d}", "bold")
        status = paint(f"{r.status:<{sw}}", *codes)
        prio = paint(f"{r.priority:<{pw}}", *priority_codes(ctx.cfg, r.priority))
        print(f"{icon} {iid} {status}  {prio}  {r.title}{tagstr}")


def cmd_ready(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    by_id = {r.id: r for r in rows}
    parents = parent_ids(rows)

    def is_ready(r):
        return (not is_terminal(ctx.cfg, r.status)        # not yet in a terminal status
                and r.id not in parents                    # a leaf (no children)
                and not is_blocked(ctx.cfg, r, by_id))     # every dep is terminal

    rows = sorted((r for r in rows if is_ready(r)),
                  key=lambda r: (priority_rank(ctx.cfg, r.priority), -r.points, r.id))
    if getattr(args, "next", False):
        rows = rows[:1]
    print_rows(ctx, rows)


def cmd_next(args) -> None:
    cmd_ready(ns_like(args, next=True))


def cmd_tree(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    kids_of = {}
    for r in rows:
        if r.parent is not None:
            kids_of.setdefault(r.parent, []).append(r)

    def children(r):
        return sorted(kids_of.get(r.id, []), key=lambda c: c.id)

    label = lambda r: node_label(ctx, r)
    if args.id is not None:
        roots = [get_row(rows, args.id)]
    else:
        roots = sorted([r for r in rows if r.parent is None and kids_of.get(r.id)],
                       key=lambda r: r.id)
        if not roots:
            print("no hierarchies (no epic has child issues yet)")
            return
    for root in roots:
        print(label(root))
        walk_tree(children(root), children, label, seen=frozenset({root.id}))


def cmd_deps(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    by_id = {r.id: r for r in rows}
    row = get_row(rows, args.id)
    reverse = {}
    for r in rows:
        for dep in r.depends_on:
            reverse.setdefault(dep, []).append(r)

    def requires(r):
        return [by_id[d] for d in sorted(r.depends_on) if d in by_id]

    def blocks(r):
        return sorted(reverse.get(r.id, []), key=lambda x: x.id)

    label = lambda r: node_label(ctx, r)
    show_requires = args.requires or not args.blocks
    show_blocks = args.blocks or not args.requires
    print(label(row))
    if show_requires:
        reqs = requires(row)
        print("\nrequires (must be done first):" if reqs else "\nrequires: none")
        walk_tree(reqs, requires, label, seen=frozenset({row.id}))
    if show_blocks:
        blk = blocks(row)
        print("\nblocks (these are waiting on it):" if blk else "\nblocks: none")
        walk_tree(blk, blocks, label, seen=frozenset({row.id}))


def cmd_check(args) -> None:
    ctx = build_ctx(args)
