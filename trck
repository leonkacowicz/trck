#!/usr/bin/env python3
"""trck — a deterministic, single-file, in-repo issue tracker.

Bookkeeping is scripted; prose is hand-authored, so the tracker can't drift.
Status = the folder a markdown file lives in; other metadata lives in index.jsonl;
SUMMARY.md is generated. Python standard library only. See README.md.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import urllib.error
import urllib.request
from datetime import date
from pathlib import Path

__version__ = "0.0.1"
DEFAULT_UPDATE_REPO = "leonkacowicz/trck"
SELF_PATH = Path(__file__).resolve()  # the running engine file; tests may override

SLUG_RE = re.compile(r"^[a-z0-9][a-z0-9-]*$")
FILENAME_RE = re.compile(r"^(\d{3,})-([a-z0-9][a-z0-9-]*)\.md$")


def die(msg: str):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def today() -> str:
    return date.today().isoformat()


def slugify(text: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")


# --------------------------------------------------------------------------- #
# config + discovery
# --------------------------------------------------------------------------- #
DEFAULT_CONFIG = {
    "update": {"repo": DEFAULT_UPDATE_REPO, "channel": "stable"},
    "statuses": [
        {"name": "backlog", "role": "initial"},
        {"name": "ongoing"},
        {"name": "done", "role": "terminal"},
    ],
    "aliases": {"start": "ongoing", "done": "done"},
    "priorities": ["high", "medium", "low"],
    "kinds": ["task", "epic"],
    "resolutions": ["superseded", "wontfix", "duplicate"],
}


def load_config(tracker_dir: Path) -> dict:
    """Merge trck.json (if any) over DEFAULT_CONFIG. Top-level keys override;
    the nested 'update' dict is merged key-by-key."""
    cfg = json.loads(json.dumps(DEFAULT_CONFIG))  # deep copy
    path = Path(tracker_dir) / "trck.json"
    if path.exists():
        try:
            user = json.loads(path.read_text() or "{}")
        except json.JSONDecodeError as e:
            die(f"{path}: invalid JSON ({e})")
        for k, v in user.items():
            if k == "update" and isinstance(v, dict):
                cfg["update"].update(v)
            else:
                cfg[k] = v
    return cfg


def status_names(cfg: dict) -> list[str]:
    return [s["name"] for s in cfg["statuses"]]


def status_role(cfg: dict, name: str) -> str | None:
    for s in cfg["statuses"]:
        if s["name"] == name:
            return s.get("role")
    return None


def initial_status(cfg: dict) -> str:
    for s in cfg["statuses"]:
        if s.get("role") == "initial":
            return s["name"]
    return cfg["statuses"][0]["name"]


def terminal_statuses(cfg: dict) -> list[str]:
    return [s["name"] for s in cfg["statuses"] if s.get("role") == "terminal"]


def is_terminal(cfg: dict, name: str) -> bool:
    return status_role(cfg, name) == "terminal"


def resolve_alias(cfg: dict, verb: str) -> str | None:
    return cfg.get("aliases", {}).get(verb)


def find_tracker(start: Path) -> Path:
    """Walk up from `start` to the folder containing trck.json (or a child holding it)."""
    start = Path(start).resolve()
    cur = start
    while True:
        if (cur / "trck.json").exists():
            return cur
        hits = sorted(cur.glob("*/trck.json"))
        if len(hits) == 1:
            return hits[0].parent.resolve()
        if len(hits) > 1:
            die(f"ambiguous tracker under {cur} ({len(hits)} found); pass --dir")
        if cur.parent == cur:
            die("no tracker found here; run `trck init`")
        cur = cur.parent


def resolve_tracker_dir(dir_opt, env=None) -> Path:
    """Resolution order: --dir > TRCK_DIR > vendored self-location > walk up from cwd."""
    env = os.environ if env is None else env
    if dir_opt:
        p = Path(dir_opt).resolve()
        if not (p / "trck.json").exists():
            die(f"{p} is not a tracker (no trck.json)")
        return p
    if env.get("TRCK_DIR"):
        return resolve_tracker_dir(env["TRCK_DIR"], env={})
    if (SELF_PATH.parent / "trck.json").exists():
        return SELF_PATH.parent
    return find_tracker(Path.cwd())


# --------------------------------------------------------------------------- #
# context + index I/O
# --------------------------------------------------------------------------- #
CANON_KEYS = [
    "id", "slug", "title", "kind", "status", "priority", "parent",
    "milestone", "depends_on", "spec", "created", "started", "closed",
    "resolution",
]


class Ctx:
    """Resolved invocation context: the tracker dir and its merged config."""
    def __init__(self, dir: Path, cfg: dict):
        self.dir = Path(dir)
        self.cfg = cfg

    @property
    def index_path(self) -> Path:
        return self.dir / "index.jsonl"


def build_ctx(args) -> Ctx:
    d = resolve_tracker_dir(getattr(args, "dir", None))
    return Ctx(d, load_config(d))


def filename(row: dict) -> str:
    return f"{row['id']:03d}-{row['slug']}.md"


def rel_link(row: dict) -> str:
    return f"{row['status']}/{filename(row)}"


def issue_path(ctx: Ctx, row: dict) -> Path:
    return ctx.dir / row["status"] / filename(row)


def load_index(ctx: Ctx) -> list[dict]:
    if not ctx.index_path.exists():
        return []
    rows = []
    for n, line in enumerate(ctx.index_path.read_text().splitlines(), 1):
        line = line.strip()
        if not line:
            continue
        try:
            row = json.loads(line)
        except json.JSONDecodeError as e:
            die(f"index.jsonl line {n}: invalid JSON ({e})")
        row.setdefault("depends_on", [])
        rows.append(row)
    return rows


def save_index(ctx: Ctx, rows: list[dict]) -> None:
    rows = sorted(rows, key=lambda r: r["id"])
    lines = []
    for r in rows:
        ordered = {k: r.get(k, [] if k == "depends_on" else None) for k in CANON_KEYS}
        for k in sorted(r):  # preserve unknown keys, appended in stable order
            if k not in ordered:
                ordered[k] = r[k]
        lines.append(json.dumps(ordered, ensure_ascii=False))
    ctx.index_path.write_text("\n".join(lines) + ("\n" if lines else ""))


def get_row(rows: list[dict], issue_id: int) -> dict:
    for r in rows:
        if r["id"] == issue_id:
            return r
    die(f"no issue with id {issue_id}")


def next_id(ctx: Ctx) -> int:
    ids = {r["id"] for r in load_index(ctx)}
    for name in status_names(ctx.cfg):
        d = ctx.dir / name
        if d.is_dir():
            for p in d.glob("*.md"):
                m = FILENAME_RE.match(p.name)
                if m:
                    ids.add(int(m.group(1)))
    return (max(ids) + 1) if ids else 1


# --------------------------------------------------------------------------- #
# filesystem scan + validation
# --------------------------------------------------------------------------- #
def scan_files(ctx: Ctx) -> dict:
    """Map id -> (status_folder, slug, filename) for every issue markdown on disk."""
    found = {}
    for name in status_names(ctx.cfg):
        d = ctx.dir / name
        if not d.is_dir():
            continue
        for p in sorted(d.glob("*.md")):
            m = FILENAME_RE.match(p.name)
            if not m:
                continue
            iid = int(m.group(1))
            if iid in found:
                die(f"duplicate issue id {iid:03d} on disk: {found[iid][0]} and {name}")
            found[iid] = (name, m.group(2), p.name)
    return found


def validate(ctx: Ctx) -> tuple[list[str], list[str]]:
    errors, warnings = [], []
    rows = load_index(ctx)
    files = scan_files(ctx)
    by_id = {r["id"]: r for r in rows}
    names = set(status_names(ctx.cfg))
    prios = set(ctx.cfg["priorities"])
    kinds = set(ctx.cfg["kinds"])
    resolutions = set(ctx.cfg["resolutions"])

    for iid, r in by_id.items():
        if iid not in files:
            errors.append(f"#{iid:03d} in index but no markdown file on disk")
            continue
        folder, slug, fname = files[iid]
        if r.get("status") != folder:
            errors.append(f"#{iid:03d} index status '{r.get('status')}' != folder '{folder}'")
        if r.get("slug") != slug:
            errors.append(f"#{iid:03d} index slug '{r.get('slug')}' != filename slug '{slug}'")
        if fname != filename(r):
            errors.append(f"#{iid:03d} filename '{fname}' != expected '{filename(r)}'")
        if not r.get("slug") or not SLUG_RE.match(r.get("slug", "")):
            errors.append(f"#{iid:03d} bad slug '{r.get('slug')}'")
        if r.get("status") not in names:
            errors.append(f"#{iid:03d} unknown status '{r.get('status')}'")
        if r.get("kind") not in kinds:
            errors.append(f"#{iid:03d} bad kind '{r.get('kind')}'")
        if r.get("priority") not in prios:
            errors.append(f"#{iid:03d} bad priority '{r.get('priority')}'")
        res = r.get("resolution")
        if res not in (None, *resolutions):
            errors.append(f"#{iid:03d} bad resolution '{res}'")
    for iid in files:
        if iid not in by_id:
            errors.append(f"#{iid:03d} markdown file on disk but no index row")

    for r in rows:
        parent = r.get("parent")
        if parent is not None:
            if parent not in by_id:
                errors.append(f"#{r['id']:03d} parent #{parent:03d} does not exist")
            elif by_id[parent].get("kind") != "epic":
                errors.append(f"#{r['id']:03d} parent #{parent:03d} is not an epic")
        for dep in r.get("depends_on", []):
            if dep not in by_id:
                errors.append(f"#{r['id']:03d} depends_on #{dep:03d} which does not exist")

    for r in rows:  # parent cycles
        seen, cur = set(), r
        while cur and cur.get("parent") is not None:
            if cur["parent"] in seen:
                errors.append(f"#{r['id']:03d} is in a parent cycle")
                break
            seen.add(cur["parent"])
            cur = by_id.get(cur["parent"])

    children = {}
    for r in rows:
        if r.get("parent") is not None and r["parent"] in by_id:
            children.setdefault(r["parent"], []).append(r)
    term = lambda name: is_terminal(ctx.cfg, name)
    for epic in [r for r in rows if r.get("kind") == "epic"]:
        kids = children.get(epic["id"], [])
        if not kids:
            warnings.append(f"epic #{epic['id']:03d} has no child issues")
        elif all(term(k["status"]) for k in kids) and not term(epic["status"]):
            warnings.append(
                f"epic #{epic['id']:03d} has all children terminal but is still "
                f"{epic['status']} (run `trck done {epic['id']}` or `trck mv …`)"
            )
    for r in rows:
        p = r.get("parent")
        if p is not None and p in by_id and term(by_id[p]["status"]) and not term(r["status"]):
            warnings.append(f"#{r['id']:03d} is {r['status']} but its epic #{p:03d} is terminal")
        if term(r["status"]):
            for dep in r.get("depends_on", []):
                if dep in by_id and not term(by_id[dep]["status"]):
                    warnings.append(f"#{r['id']:03d} is terminal but depends on non-terminal #{dep:03d}")
    return errors, warnings


# --------------------------------------------------------------------------- #
# tree rendering helpers (used by SUMMARY, tree, deps)
# --------------------------------------------------------------------------- #
STATUS_ICON = {"terminal": "✅", "initial": "☐", None: "⏳"}


def status_icon(ctx: Ctx, name: str) -> str:
    return STATUS_ICON.get(status_role(ctx.cfg, name), "⏳")


def node_label(ctx: Ctx, r: dict) -> str:
    ms = f"{r['milestone']} — " if r.get("milestone") else ""
    tag = " ·epic·" if r.get("kind") == "epic" else ""
    return f"#{r['id']:03d} {status_icon(ctx, r['status'])} {ms}{r['title']}{tag}"


def walk_tree(nodes, children_fn, label_fn, prefix="", seen=frozenset()):
    nodes = list(nodes)
    for i, node in enumerate(nodes):
        last = i == len(nodes) - 1
        connector = "└─ " if last else "├─ "
        cycle = node["id"] in seen
        print(prefix + connector + label_fn(node) + (" (cycle)" if cycle else ""))
        if cycle:
            continue
        ext = "   " if last else "│  "
        walk_tree(children_fn(node), children_fn, label_fn, prefix + ext, seen | {node["id"]})


# --------------------------------------------------------------------------- #
# SUMMARY.md generation
# --------------------------------------------------------------------------- #
def generate_summary(ctx: Ctx) -> str:
    rows = load_index(ctx)
    children = {}
    for r in rows:
        if r.get("parent") is not None:
            children.setdefault(r["parent"], []).append(r)
    names = status_names(ctx.cfg)
    term = lambda n: is_terminal(ctx.cfg, n)

    counts = {n: 0 for n in names}
    for r in rows:
        counts[r["status"]] = counts.get(r["status"], 0) + 1
    total = len(rows)

    out = []
    out.append("<!-- GENERATED by `trck summary` — do not hand-edit. -->")
    out.append("# Issues Summary")
    out.append("")
    out.append("## Counts")
    out.append("")
    out.append("| State | Count |")
    out.append("|---|---:|")
    for n in names:
        out.append(f"| {n} | {counts[n]} |")
    out.append(f"| **total** | **{total}** |")
    out.append("")

    epics = sorted([r for r in rows if r.get("kind") == "epic"], key=lambda r: r["id"])
    if epics:
        out.append("## Epics")
        out.append("")
        for epic in epics:
            kids = sorted(children.get(epic["id"], []),
                          key=lambda r: (r.get("milestone") or "", r["id"]))
            ndone = sum(1 for k in kids if term(k["status"]))
            pct = round(100 * ndone / len(kids)) if kids else 0
            out.append(
                f"### [#{epic['id']:03d} {epic['title']}]({rel_link(epic)}) — "
                f"{pct}% ({ndone}/{len(kids)}) · _{epic['priority']}_ · {epic['status']}"
            )
            if epic.get("spec"):
                out.append(f"Spec: [`{epic['spec']}`](../{epic['spec']})")
            if kids:
                strip = " · ".join(
                    f"{(k.get('milestone') or '?')} {status_icon(ctx, k['status'])}" for k in kids
                )
                out.append("")
                out.append(strip)
                out.append("")
                for k in kids:
                    box = "x" if term(k["status"]) else " "
                    ms = f"{k['milestone']} — " if k.get("milestone") else ""
                    tail = "" if term(k["status"]) else f" _({k['status']})_"
                    out.append(f"- [{box}] [#{k['id']:03d} {ms}{k['title']}]({rel_link(k)}){tail}")
            out.append("")

    def standalone(status):
        return sorted(
            [r for r in rows if r["status"] == status and r.get("kind") != "epic"
             and r.get("parent") is None],
            key=lambda r: r["id"],
        )

    for status in names:
        items = standalone(status)
        out.append(f"## {status.capitalize()}")
        out.append("")
        if not items:
            out.append("_none_")
        for r in items:
            extra = ""
            if r.get("resolution"):
                extra += f" · _{r['resolution']}_"
            if is_terminal(ctx.cfg, status) and r.get("closed"):
                extra += f" (closed {r['closed']})"
            out.append(f"- [#{r['id']:03d} {r['title']}]({rel_link(r)}) — _{r['priority']}_{extra}")
        out.append("")

    return "\n".join(out).rstrip() + "\n"


def write_summary(ctx: Ctx) -> None:
    (ctx.dir / "SUMMARY.md").write_text(generate_summary(ctx))


# --------------------------------------------------------------------------- #
# finalize: persist + regenerate + validate after every mutation
# --------------------------------------------------------------------------- #
def finalize(ctx: Ctx, rows: list[dict]) -> None:
    save_index(ctx, rows)
    write_summary(ctx)
    errors, warnings = validate(ctx)
    for w in warnings:
        print(f"warning: {w}", file=sys.stderr)
    if errors:
        print("\nINCONSISTENCIES after this operation:", file=sys.stderr)
        for e in errors:
            print(f"  error: {e}", file=sys.stderr)
        print("the tracker is now inconsistent — fix before committing.", file=sys.stderr)


# --------------------------------------------------------------------------- #
# TEMPLATE, parse_ids, move_issue, cmd_new, cmd_mv
# --------------------------------------------------------------------------- #

TEMPLATE = """# {title}

## Summary
<!-- What needs doing and why. For an epic, link the spec instead of re-narrating it. -->

## Acceptance criteria
- [ ]

## Notes
<!-- Context, links to files/commits, open questions, decisions. -->
"""


def parse_ids(spec):
    if not spec:
        return []
    return [int(p.strip()) for p in spec.split(",") if p.strip()]


def move_issue(ctx: Ctx, row: dict, new_status: str) -> None:
    """Move the file between status folders and stamp dates from roles."""
    if new_status not in status_names(ctx.cfg):
        die(f"unknown status '{new_status}' (configured: {', '.join(status_names(ctx.cfg))})")
    old_status = row["status"]
    old = issue_path(ctx, row)
    row["status"] = new_status
    new = issue_path(ctx, row)
    if old.resolve() != new.resolve():
        new.parent.mkdir(parents=True, exist_ok=True)
        if not old.exists():
            die(f"file missing for #{row['id']:03d}: {old}")
        shutil.move(str(old), str(new))

    init = initial_status(ctx.cfg)
    if old_status == init and new_status != init and not row.get("started"):
        row["started"] = today()
    if is_terminal(ctx.cfg, new_status):
        if not row.get("closed"):
            row["closed"] = today()
    else:
        row["closed"] = None
        row["resolution"] = None


def cmd_new(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    by_id = {r["id"]: r for r in rows}
    iid = next_id(ctx)
    slug = args.slug or slugify(args.title)
    if not SLUG_RE.match(slug):
        die(f"computed slug '{slug}' is invalid; pass --slug")
    priority = args.priority or ctx.cfg["priorities"][0]
    if priority not in ctx.cfg["priorities"]:
        die(f"bad priority '{priority}' (configured: {', '.join(ctx.cfg['priorities'])})")
    kind = "epic" if args.epic else "task"
    parent = args.parent
    if parent is not None:
        if parent not in by_id:
            die(f"--parent #{parent:03d} does not exist")
        if by_id[parent].get("kind") != "epic":
            die(f"--parent #{parent:03d} is not an epic")
    deps = parse_ids(args.depends)
    for dep in deps:
        if dep not in by_id:
            die(f"--depends references #{dep:03d} which does not exist")
    row = {
        "id": iid, "slug": slug, "title": args.title, "kind": kind,
        "status": initial_status(ctx.cfg), "priority": priority,
        "parent": parent, "milestone": args.milestone, "depends_on": deps,
        "spec": args.spec, "created": today(), "started": None,
        "closed": None, "resolution": None,
    }
    path = issue_path(ctx, row)
    if path.exists():
        die(f"{path} already exists")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(TEMPLATE.format(title=args.title))
    rows.append(row)
    finalize(ctx, rows)
    print(path)


def cmd_mv(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    row = get_row(rows, args.id)
    resolution = getattr(args, "resolution", None)
    if resolution is not None:
        if not is_terminal(ctx.cfg, args.status):
            die(f"--resolution is only valid when moving to a terminal status")
        if resolution not in ctx.cfg["resolutions"]:
            die(f"bad resolution '{resolution}' (configured: {', '.join(ctx.cfg['resolutions'])})")
    move_issue(ctx, row, args.status)
    if resolution is not None:
        row["resolution"] = resolution
    finalize(ctx, rows)
    print(issue_path(ctx, row))


def cmd_set(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    by_id = {r["id"]: r for r in rows}
    row = get_row(rows, args.id)
    if args.priority:
        if args.priority not in ctx.cfg["priorities"]:
            die(f"bad priority '{args.priority}'")
        row["priority"] = args.priority
    if args.parent is not None:
        if args.parent == "none":
            row["parent"] = None
        else:
            pid = int(args.parent)
            if pid not in by_id or by_id[pid].get("kind") != "epic":
                die(f"--parent #{pid:03d} must be an existing epic")
            row["parent"] = pid
    if args.milestone is not None:
        row["milestone"] = None if args.milestone == "none" else args.milestone
    if args.spec is not None:
        row["spec"] = None if args.spec == "none" else args.spec
    if args.kind:
        if args.kind not in ctx.cfg["kinds"]:
            die(f"bad kind '{args.kind}'")
        row["kind"] = args.kind
    if args.title:
        row["title"] = args.title
    finalize(ctx, rows)
    print(f"#{row['id']:03d} updated")


def cmd_dep(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    by_id = {r["id"]: r for r in rows}
    row = get_row(rows, args.id)
    deps = list(row.get("depends_on", []))
    if args.add is not None:
        if args.add not in by_id:
            die(f"#{args.add:03d} does not exist")
        if args.add not in deps:
            deps.append(args.add)
    if args.remove is not None and args.remove in deps:
        deps.remove(args.remove)
    row["depends_on"] = sorted(deps)
    finalize(ctx, rows)
    print(f"#{row['id']:03d} depends_on={row['depends_on']}")


def cmd_rename(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    row = get_row(rows, args.id)
    new_slug = args.slug or slugify(args.title)
    if not SLUG_RE.match(new_slug):
        die(f"computed slug '{new_slug}' is invalid; pass --slug")
    old = issue_path(ctx, row)
    row["title"] = args.title
    row["slug"] = new_slug
    new = issue_path(ctx, row)
    if old.resolve() != new.resolve():
        shutil.move(str(old), str(new))
    text = new.read_text()
    text = re.sub(r"^# .*$", f"# {args.title}", text, count=1, flags=re.MULTILINE)
    new.write_text(text)
    finalize(ctx, rows)
    print(new)


def cmd_show(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    row = get_row(rows, args.id)
    printable = {k: row.get(k) for k in CANON_KEYS}
    for k in sorted(row):
        if k not in printable:
            printable[k] = row[k]
    print(json.dumps(printable, ensure_ascii=False, indent=2))
    print("\n--- body ---\n")
    print(issue_path(ctx, row).read_text())


def cmd_list(args) -> None:
    ctx = build_ctx(args)
    rows = sorted(load_index(ctx), key=lambda r: r["id"])
    for r in rows:
        if args.status and r["status"] != args.status:
            continue
        if args.kind and r.get("kind") != args.kind:
            continue
        if args.priority and r.get("priority") != args.priority:
            continue
        if args.epic is not None and r.get("parent") != args.epic:
            continue
        tags = []
        if r.get("kind") == "epic":
            tags.append("EPIC")
        if r.get("parent"):
            tags.append(f"↳{r['parent']:03d}")
        if r.get("milestone"):
            tags.append(r["milestone"])
        tagstr = (" [" + " ".join(tags) + "]") if tags else ""
        print(f"#{r['id']:03d} {r['status']:10} {r['priority']:6} {r['title']}{tagstr}")


def cmd_tree(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    kids_of = {}
    for r in rows:
        if r.get("parent") is not None:
            kids_of.setdefault(r["parent"], []).append(r)

    def children(r):
        return sorted(kids_of.get(r["id"], []), key=lambda c: (c.get("milestone") or "", c["id"]))

    label = lambda r: node_label(ctx, r)
    if args.id is not None:
        roots = [get_row(rows, args.id)]
    else:
        roots = sorted([r for r in rows if r.get("parent") is None and kids_of.get(r["id"])],
                       key=lambda r: r["id"])
        if not roots:
            print("no hierarchies (no epic has child issues yet)")
            return
    for root in roots:
        print(label(root))
        walk_tree(children(root), children, label, seen=frozenset({root["id"]}))


def cmd_deps(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    by_id = {r["id"]: r for r in rows}
    row = get_row(rows, args.id)
    reverse = {}
    for r in rows:
        for dep in r.get("depends_on", []):
            reverse.setdefault(dep, []).append(r)

    def requires(r):
        return [by_id[d] for d in sorted(r.get("depends_on", [])) if d in by_id]

    def blocks(r):
        return sorted(reverse.get(r["id"], []), key=lambda x: x["id"])

    label = lambda r: node_label(ctx, r)
    show_requires = args.requires or not args.blocks
    show_blocks = args.blocks or not args.requires
    print(label(row))
    if show_requires:
        reqs = requires(row)
        print("\nrequires (must be done first):" if reqs else "\nrequires: none")
        walk_tree(reqs, requires, label, seen=frozenset({row["id"]}))
    if show_blocks:
        blk = blocks(row)
        print("\nblocks (these are waiting on it):" if blk else "\nblocks: none")
        walk_tree(blk, blocks, label, seen=frozenset({row["id"]}))


