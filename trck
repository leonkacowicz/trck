def parse_ids(spec):
    if not spec:
        return []
    return [int(p.strip()) for p in spec.split(",") if p.strip()]


def move_issue(ctx: Ctx, row: dict, new_status: str) -> None:
    """Move the file between status folders and stamp dates from roles."""
    if new_status not in status_names(ctx.cfg):
        die(f"unknown status '{new_status}' (configured: {', '.join(status_names(ctx.cfg))})")
    old_status = row["status"]
    old = issue_path(ctx, row)
    row["status"] = new_status
    new = issue_path(ctx, row)
    if old.resolve() != new.resolve():
        new.parent.mkdir(parents=True, exist_ok=True)
        if not old.exists():
            die(f"file missing for #{row['id']:03d}: {old}")
        shutil.move(str(old), str(new))

    init = initial_status(ctx.cfg)
    if old_status == init and new_status != init and not row.get("started"):
        row["started"] = today()
    if is_terminal(ctx.cfg, new_status):
        if not row.get("closed"):
            row["closed"] = today()
    else:
        row["closed"] = None
        row["resolution"] = None


def cmd_new(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    by_id = {r["id"]: r for r in rows}
    iid = next_id(ctx)
    slug = args.slug or slugify(args.title)
    if not SLUG_RE.match(slug):
        die(f"computed slug '{slug}' is invalid; pass --slug")
    priority = args.priority or ctx.cfg["priorities"][0]
    if priority not in ctx.cfg["priorities"]:
        die(f"bad priority '{priority}' (configured: {', '.join(ctx.cfg['priorities'])})")
    kind = "epic" if args.epic else "task"
    parent = args.parent
    if parent is not None and parent not in by_id:
        die(f"--parent #{parent:03d} does not exist")
    deps = parse_ids(args.depends)
    for dep in deps:
        if dep not in by_id:
            die(f"--depends references #{dep:03d} which does not exist")
    row = {
        "id": iid, "slug": slug, "title": args.title, "kind": kind,
        "status": initial_status(ctx.cfg), "priority": priority,
        "parent": parent, "milestone": args.milestone, "depends_on": deps,
        "spec": args.spec, "created": today(), "started": None,
        "closed": None, "resolution": None,
    }
    path = issue_path(ctx, row)
    if path.exists():
        die(f"{path} already exists")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(TEMPLATE.format(title=args.title))
    rows.append(row)
    finalize(ctx, rows)
    print(path)


def cmd_mv(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    row = get_row(rows, args.id)
    resolution = getattr(args, "resolution", None)
    if resolution is not None:
        if not is_terminal(ctx.cfg, args.status):
            die(f"--resolution is only valid when moving to a terminal status")
        if resolution not in ctx.cfg["resolutions"]:
            die(f"bad resolution '{resolution}' (configured: {', '.join(ctx.cfg['resolutions'])})")
    move_issue(ctx, row, args.status)
    if resolution is not None:
        row["resolution"] = resolution
    finalize(ctx, rows)
    print(issue_path(ctx, row))


def cmd_set(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    by_id = {r["id"]: r for r in rows}
    row = get_row(rows, args.id)
    if args.priority:
        if args.priority not in ctx.cfg["priorities"]:
            die(f"bad priority '{args.priority}'")
        row["priority"] = args.priority
    if args.parent is not None:
        if args.parent == "none":
            row["parent"] = None
        else:
            pid = int(args.parent)
            if pid not in by_id:
                die(f"--parent #{pid:03d} must be an existing issue")
            row["parent"] = pid
    if args.milestone is not None:
        row["milestone"] = None if args.milestone == "none" else args.milestone
    if args.spec is not None:
        row["spec"] = None if args.spec == "none" else args.spec
    if args.kind:
        if args.kind not in ctx.cfg["kinds"]:
            die(f"bad kind '{args.kind}'")
        row["kind"] = args.kind
    if args.title:
        row["title"] = args.title
    finalize(ctx, rows)
    print(f"#{row['id']:03d} updated")


def cmd_dep(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    by_id = {r["id"]: r for r in rows}
    row = get_row(rows, args.id)
    deps = list(row.get("depends_on", []))
    if args.add is not None:
        if args.add not in by_id:
            die(f"#{args.add:03d} does not exist")
        if args.add not in deps:
            deps.append(args.add)
    if args.remove is not None and args.remove in deps:
        deps.remove(args.remove)
    row["depends_on"] = sorted(deps)
    finalize(ctx, rows)
    print(f"#{row['id']:03d} depends_on={row['depends_on']}")


def cmd_rename(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    row = get_row(rows, args.id)
    new_slug = args.slug or slugify(args.title)
    if not SLUG_RE.match(new_slug):
        die(f"computed slug '{new_slug}' is invalid; pass --slug")
    old = issue_path(ctx, row)
    row["title"] = args.title
    row["slug"] = new_slug
    new = issue_path(ctx, row)
    if old.resolve() != new.resolve():
        shutil.move(str(old), str(new))
    text = new.read_text()
    text = re.sub(r"^# .*$", f"# {args.title}", text, count=1, flags=re.MULTILINE)
    new.write_text(text)
    finalize(ctx, rows)
    print(new)


def cmd_show(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    row = get_row(rows, args.id)
    printable = {k: row.get(k) for k in CANON_KEYS}
    for k in sorted(row):
        if k not in printable:
            printable[k] = row[k]
    print(json.dumps(printable, ensure_ascii=False, indent=2))
    print("\n--- body ---\n")
    print(issue_path(ctx, row).read_text())


def cmd_list(args) -> None:
    ctx = build_ctx(args)
    rows = sorted(load_index(ctx), key=lambda r: r["id"])
    for r in rows:
        if args.status and r["status"] != args.status:
            continue
        if args.kind and r.get("kind") != args.kind:
            continue
        if args.priority and r.get("priority") != args.priority:
            continue
        if args.epic is not None and r.get("parent") != args.epic:
            continue
        tags = []
        if r.get("kind") == "epic":
            tags.append("EPIC")
        if r.get("parent"):
            tags.append(f"↳{r['parent']:03d}")
        if r.get("milestone"):
            tags.append(r["milestone"])
        tagstr = (" [" + " ".join(tags) + "]") if tags else ""
        print(f"#{r['id']:03d} {r['status']:10} {r['priority']:6} {r['title']}{tagstr}")


def cmd_tree(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    kids_of = {}
    for r in rows:
        if r.get("parent") is not None:
            kids_of.setdefault(r["parent"], []).append(r)

    def children(r):
        return sorted(kids_of.get(r["id"], []), key=lambda c: (c.get("milestone") or "", c["id"]))

    label = lambda r: node_label(ctx, r)
    if args.id is not None:
        roots = [get_row(rows, args.id)]
    else:
        roots = sorted([r for r in rows if r.get("parent") is None and kids_of.get(r["id"])],
                       key=lambda r: r["id"])
        if not roots:
            print("no hierarchies (no epic has child issues yet)")
            return
    for root in roots:
        print(label(root))
        walk_tree(children(root), children, label, seen=frozenset({root["id"]}))


def cmd_deps(args) -> None:
    ctx = build_ctx(args)
    rows = load_index(ctx)
    by_id = {r["id"]: r for r in rows}
    row = get_row(rows, args.id)
    reverse = {}
    for r in rows:
        for dep in r.get("depends_on", []):
            reverse.setdefault(dep, []).append(r)

    def requires(r):
        return [by_id[d] for d in sorted(r.get("depends_on", [])) if d in by_id]

    def blocks(r):
        return sorted(reverse.get(r["id"], []), key=lambda x: x["id"])

    label = lambda r: node_label(ctx, r)
    show_requires = args.requires or not args.blocks
    show_blocks = args.blocks or not args.requires
    print(label(row))
    if show_requires:
        reqs = requires(row)
        print("\nrequires (must be done first):" if reqs else "\nrequires: none")
        walk_tree(reqs, requires, label, seen=frozenset({row["id"]}))
    if show_blocks:
        blk = blocks(row)
        print("\nblocks (these are waiting on it):" if blk else "\nblocks: none")
        walk_tree(blk, blocks, label, seen=frozenset({row["id"]}))


def cmd_check(args) -> None:
    ctx = build_ctx(args)
    errors, warnings = validate(ctx)
    for w in warnings:
        print(f"warning: {w}")
    for e in errors:
        print(f"error: {e}")
    if errors:
        print(f"\n{len(errors)} error(s), {len(warnings)} warning(s) — FAIL")
        sys.exit(1)
    print(f"OK — {len(load_index(ctx))} issues, 0 errors, {len(warnings)} warning(s)")


def cmd_summary(args) -> None:
    ctx = build_ctx(args)
    write_summary(ctx)
    print(f"wrote {ctx.dir / 'SUMMARY.md'} ({len(load_index(ctx))} issues)")


def cmd_install_hook(args) -> None:
    ctx = build_ctx(args)
    common = subprocess.run(["git", "rev-parse", "--git-common-dir"],
                            cwd=ctx.dir, capture_output=True, text=True)
    toplevel = subprocess.run(["git", "rev-parse", "--show-toplevel"],
                              cwd=ctx.dir, capture_output=True, text=True)
    if common.returncode != 0 or toplevel.returncode != 0:
        die("not a git repository")
    root = Path(toplevel.stdout.strip())
    try:
        rel = ctx.dir.resolve().relative_to(root.resolve()).as_posix()
    except ValueError:
        die(f"tracker dir {ctx.dir} is not inside the git repo at {root}")
    hooks = (ctx.dir / common.stdout.strip()).resolve() / "hooks"
    hooks.mkdir(parents=True, exist_ok=True)
    hook = hooks / "pre-commit"
    rel_re = rel.replace(".", r"\.")
    body = (
        "#!/usr/bin/env bash\n"
        "# Auto-installed by `trck install-hook`. Runs `trck check` when the tracker changes.\n"
        'root="$(git rev-parse --show-toplevel)"\n'
        'staged="$(git diff --cached --name-only)"\n'
        f"if printf '%s\\n' \"$staged\" | grep -qE '(^|/){rel_re}/'; then\n"
        f'  if [ -x "$root/{rel}/trck" ]; then\n'
        f'    python3 "$root/{rel}/trck" check || {{ echo "trck inconsistent — aborting commit"; exit 1; }}\n'
        '  elif command -v trck >/dev/null 2>&1; then\n'
        f'    trck --dir "$root/{rel}" check || {{ echo "trck inconsistent — aborting commit"; exit 1; }}\n'
        "  fi\n"
        "fi\n"
    )
    hook.write_text(body)
    hook.chmod(0o755)
    print(f"installed {hook}")


def cmd_version(args) -> None:
    print(__version__)
    ctx = build_ctx(args, required=False)  # version must work with no tracker (silently)
    if ctx is not None:
        print(f"tracker: {ctx.dir}", file=sys.stderr)


def cmd_start(args) -> None:
    ctx = build_ctx(args)
    target = resolve_alias(ctx.cfg, "start")
    if not target:
        die("no 'start' alias configured; use `trck mv <id> <status>`")
    cmd_mv(ns_like(args, status=target, resolution=None))


def cmd_done(args) -> None:
    ctx = build_ctx(args)
    target = resolve_alias(ctx.cfg, "done")
    if not target:
        die("no 'done' alias configured; use `trck mv <id> <status>`")
    cmd_mv(ns_like(args, status=target, resolution=getattr(args, "resolution", None)))


def ns_like(args, **over):
    """Clone an argparse Namespace with overrides (for alias delegation)."""
    data = dict(vars(args))
    data.update(over)
    return argparse.Namespace(**data)


def cmd_init(args) -> None:
    target = (Path.cwd() / args.init_dir).resolve()
    cfgfile = target / "trck.json"
    if cfgfile.exists() and not args.force:
        die(f"{target} is already a tracker (pass --force to overwrite config)")
    target.mkdir(parents=True, exist_ok=True)

    config = json.loads(json.dumps(DEFAULT_CONFIG))
    config["update"]["repo"] = DEFAULT_UPDATE_REPO
    cfgfile.write_text(json.dumps(config, indent=2) + "\n")

    vendored = target / "trck"
    shutil.copyfile(SELF_PATH, vendored)
    shutil.copymode(SELF_PATH, vendored)
    os.chmod(vendored, os.stat(vendored).st_mode | 0o111)

    claude = target / "CLAUDE.md"
    if not claude.exists() or args.force:
        claude.write_text(CLAUDE_MD_TEMPLATE)
    readme = target / "README.md"
    if not readme.exists() or args.force:
        readme.write_text(README_TEMPLATE)

    if args.hook:
        cmd_install_hook(ns_like(args, dir=str(target)))
    print(f"initialized tracker at {target}")


def _update_repo(args) -> str:
    """Resolve which GitHub repo to update from: tracker config if available, else default."""
    ctx = build_ctx(args, required=False)  # update works outside a tracker (silently)
    if ctx is None:
        return DEFAULT_UPDATE_REPO
    return ctx.cfg.get("update", {}).get("repo") or DEFAULT_UPDATE_REPO


def _current_version() -> str:
    """Read __version__ from the SELF_PATH file (so tests can override SELF_PATH)."""
    text = Path(SELF_PATH).read_text()
    m = re.search(r'^__version__\s*=\s*["\']([^"\']+)["\']', text, re.MULTILINE)
    return m.group(1) if m else __version__


def cmd_update(args) -> None:
    repo = _update_repo(args)
    cur_ver = _current_version()
    try:
        if args.ref:
            ref = args.ref
            tag, notes = args.ref, ""
        else:
            tag, notes = latest_release(repo)
            ref = tag
            if parse_version(tag) <= parse_version(cur_ver):
                print(f"already up to date (v{cur_ver}; latest {tag})")
                return
        if args.check:
            print(f"update available: {cur_ver} -> {tag}\n{notes}")
            return
        raw = f"https://raw.githubusercontent.com/{repo}/{ref}/trck"
        source = fetch_url(raw)
    except (urllib.error.URLError, urllib.error.HTTPError) as e:
        die(f"update failed (network): {e}")
    except (KeyError, json.JSONDecodeError) as e:
        die(f"update failed (bad response): {e}")

    try:
        compile(source, "<trck-update>", "exec")
    except SyntaxError as e:
        die(f"downloaded trck did not compile; aborting (left current file intact): {e}")
    if "__version__" not in source:
        die("downloaded file does not look like trck (no __version__); aborting, file left intact")

    target = Path(SELF_PATH)
    tmp = target.with_name(target.name + ".trck-update.tmp")
    try:
        tmp.write_text(source)
        try:
            shutil.copymode(target, tmp)
        except OSError:
            pass
        os.replace(tmp, target)
    except OSError as e:
        tmp.unlink(missing_ok=True)
        die(f"update failed (write): {e}")
    print(f"updated {target} to {ref}")
    if notes:
        print(f"\n{notes}")


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="trck", description="deterministic in-repo issue tracker")
    p.add_argument("--dir", help="tracker dir (overrides discovery and $TRCK_DIR)")
    sub = p.add_subparsers(dest="cmd", required=True)

    n = sub.add_parser("new", help="create a new issue (then edit its prose)")
    n.add_argument("title")
    n.add_argument("--priority")
    n.add_argument("--epic", action="store_true")
    n.add_argument("--parent", type=int)
    n.add_argument("--milestone")
    n.add_argument("--depends")
    n.add_argument("--spec")
    n.add_argument("--slug")
    n.set_defaults(func=cmd_new, priority=None)

    mv = sub.add_parser("mv", help="move an issue to a status (vocabulary-agnostic)")
    mv.add_argument("id", type=int)
    mv.add_argument("status")
    mv.add_argument("--resolution")
    mv.set_defaults(func=cmd_mv)

    st = sub.add_parser("start", help="alias: move to the configured 'start' status")
    st.add_argument("id", type=int)
    st.set_defaults(func=cmd_start)

    dn = sub.add_parser("done", help="alias: move to the configured 'done' status")
    dn.add_argument("id", type=int)
    dn.add_argument("--resolution")
    dn.set_defaults(func=cmd_done)

    se = sub.add_parser("set", help="edit metadata fields (index only)")
    se.add_argument("id", type=int)
    se.add_argument("--priority")
    se.add_argument("--parent", help="epic id, or 'none' to clear")
    se.add_argument("--milestone", help="label, or 'none' to clear")
    se.add_argument("--spec", help="path, or 'none' to clear")
    se.add_argument("--kind")
    se.add_argument("--title")
    se.set_defaults(func=cmd_set)

    dp = sub.add_parser("dep", help="add/remove a dependency edge")
    dp.add_argument("id", type=int)
    dp.add_argument("--add", type=int)
    dp.add_argument("--remove", type=int)
    dp.set_defaults(func=cmd_dep)

    rn = sub.add_parser("rename", help="change title + slug (renames the file)")
    rn.add_argument("id", type=int)
    rn.add_argument("title")
    rn.add_argument("--slug")
    rn.set_defaults(func=cmd_rename)

    sh = sub.add_parser("show", help="print an issue's metadata + body")
    sh.add_argument("id", type=int)
    sh.set_defaults(func=cmd_show)

    ls = sub.add_parser("list", help="list issues (filterable)")
    ls.add_argument("--status")
    ls.add_argument("--kind")
    ls.add_argument("--priority")
    ls.add_argument("--epic", type=int)
    ls.set_defaults(func=cmd_list)

    tr = sub.add_parser("tree", help="print an issue's child hierarchy")
    tr.add_argument("id", type=int, nargs="?")
    tr.set_defaults(func=cmd_tree)

    dz = sub.add_parser("deps", help="show what an issue requires and what it blocks")
    dz.add_argument("id", type=int)
    dz.add_argument("--requires", action="store_true")
    dz.add_argument("--blocks", action="store_true")
    dz.set_defaults(func=cmd_deps)

    ck = sub.add_parser("check", help="validate consistency (nonzero exit on error)")
    ck.set_defaults(func=cmd_check)

    su = sub.add_parser("summary", help="regenerate SUMMARY.md")
    su.set_defaults(func=cmd_summary)

    ih = sub.add_parser("install-hook", help="install the pre-commit consistency hook")
    ih.set_defaults(func=cmd_install_hook)

    iv = sub.add_parser("init", help="scaffold a tracker into the current repo")
    iv.add_argument("--dir", dest="init_dir", default="issues")
    iv.add_argument("--hook", action="store_true")
    iv.add_argument("--force", action="store_true")
    iv.set_defaults(func=cmd_init)

    up = sub.add_parser("update", help="self-update from the canonical repo")
    up.add_argument("--check", action="store_true")
    up.add_argument("--ref")
    up.set_defaults(func=cmd_update)

    ve = sub.add_parser("version", help="print the running trck version")
    ve.set_defaults(func=cmd_version)

    return p


def main() -> None:
    args = build_parser().parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
