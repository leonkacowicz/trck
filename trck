#!/usr/bin/env python3
"""trck — a deterministic, single-file, in-repo issue tracker.

Bookkeeping is scripted; prose is hand-authored, so the tracker can't drift.
Status = the folder a markdown file lives in; other metadata lives in index.jsonl;
SUMMARY.md is generated. Python standard library only. See README.md.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import urllib.error
import urllib.request
from datetime import date
from pathlib import Path

__version__ = "0.0.1"
DEFAULT_UPDATE_REPO = "leonkacowicz/trck"
SELF_PATH = Path(__file__).resolve()  # the running engine file; tests may override

SLUG_RE = re.compile(r"^[a-z0-9][a-z0-9-]*$")
FILENAME_RE = re.compile(r"^(\d{3,})-([a-z0-9][a-z0-9-]*)\.md$")


def die(msg: str):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def today() -> str:
    return date.today().isoformat()


def slugify(text: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")


# --------------------------------------------------------------------------- #
# config + discovery
# --------------------------------------------------------------------------- #
DEFAULT_CONFIG = {
    "update": {"repo": DEFAULT_UPDATE_REPO, "channel": "stable"},
    "statuses": [
        {"name": "backlog", "role": "initial"},
        {"name": "ongoing"},
        {"name": "done", "role": "terminal"},
    ],
    "aliases": {"start": "ongoing", "done": "done"},
    "priorities": ["high", "medium", "low"],
    "kinds": ["task", "epic"],
    "resolutions": ["superseded", "wontfix", "duplicate"],
}


def load_config(tracker_dir: Path) -> dict:
    """Merge trck.json (if any) over DEFAULT_CONFIG. Top-level keys override;
    the nested 'update' dict is merged key-by-key."""
    cfg = json.loads(json.dumps(DEFAULT_CONFIG))  # deep copy
    path = Path(tracker_dir) / "trck.json"
    if path.exists():
        try:
            user = json.loads(path.read_text() or "{}")
        except json.JSONDecodeError as e:
            die(f"{path}: invalid JSON ({e})")
        for k, v in user.items():
            if k == "update" and isinstance(v, dict):
                cfg["update"].update(v)
            else:
                cfg[k] = v
    return cfg


def status_names(cfg: dict) -> list[str]:
    return [s["name"] for s in cfg["statuses"]]


def status_role(cfg: dict, name: str) -> str | None:
    for s in cfg["statuses"]:
        if s["name"] == name:
            return s.get("role")
    return None


def initial_status(cfg: dict) -> str:
    for s in cfg["statuses"]:
        if s.get("role") == "initial":
            return s["name"]
    return cfg["statuses"][0]["name"]


def terminal_statuses(cfg: dict) -> list[str]:
    return [s["name"] for s in cfg["statuses"] if s.get("role") == "terminal"]


def is_terminal(cfg: dict, name: str) -> bool:
    return status_role(cfg, name) == "terminal"


def resolve_alias(cfg: dict, verb: str) -> str | None:
    return cfg.get("aliases", {}).get(verb)


def find_tracker(start: Path) -> Path:
    """Walk up from `start` to the folder containing trck.json (or a child holding it)."""
    start = Path(start).resolve()
    cur = start
    while True:
        if (cur / "trck.json").exists():
            return cur
        hits = sorted(cur.glob("*/trck.json"))
        if len(hits) == 1:
            return hits[0].parent.resolve()
        if len(hits) > 1:
            die(f"ambiguous tracker under {cur} ({len(hits)} found); pass --dir")
        if cur.parent == cur:
            die("no tracker found here; run `trck init`")
        cur = cur.parent


def resolve_tracker_dir(dir_opt, env=None) -> Path:
    """Resolution order: --dir > TRCK_DIR > vendored self-location > walk up from cwd."""
    env = os.environ if env is None else env
    if dir_opt:
        p = Path(dir_opt).resolve()
        if not (p / "trck.json").exists():
            die(f"{p} is not a tracker (no trck.json)")
        return p
    if env.get("TRCK_DIR"):
        return resolve_tracker_dir(env["TRCK_DIR"], env={})
    if (SELF_PATH.parent / "trck.json").exists():
        return SELF_PATH.parent
    return find_tracker(Path.cwd())


# --------------------------------------------------------------------------- #
# context + index I/O
# --------------------------------------------------------------------------- #
CANON_KEYS = [
    "id", "slug", "title", "kind", "status", "priority", "parent",
    "milestone", "depends_on", "spec", "created", "started", "closed",
    "resolution",
]


class Ctx:
    """Resolved invocation context: the tracker dir and its merged config."""
    def __init__(self, dir: Path, cfg: dict):
        self.dir = Path(dir)
        self.cfg = cfg

    @property
    def index_path(self) -> Path:
        return self.dir / "index.jsonl"


def build_ctx(args) -> Ctx:
    d = resolve_tracker_dir(getattr(args, "dir", None))
    return Ctx(d, load_config(d))


def filename(row: dict) -> str:
    return f"{row['id']:03d}-{row['slug']}.md"


def rel_link(row: dict) -> str:
    return f"{row['status']}/{filename(row)}"


def issue_path(ctx: Ctx, row: dict) -> Path:
    return ctx.dir / row["status"] / filename(row)


def load_index(ctx: Ctx) -> list[dict]:
    if not ctx.index_path.exists():
        return []
    rows = []
    for n, line in enumerate(ctx.index_path.read_text().splitlines(), 1):
        line = line.strip()
        if not line:
            continue
        try:
            row = json.loads(line)
        except json.JSONDecodeError as e:
            die(f"index.jsonl line {n}: invalid JSON ({e})")
        row.setdefault("depends_on", [])
        rows.append(row)
    return rows


def save_index(ctx: Ctx, rows: list[dict]) -> None:
    rows = sorted(rows, key=lambda r: r["id"])
    lines = []
    for r in rows:
        ordered = {k: r.get(k, [] if k == "depends_on" else None) for k in CANON_KEYS}
        for k in sorted(r):  # preserve unknown keys, appended in stable order
            if k not in ordered:
                ordered[k] = r[k]
        lines.append(json.dumps(ordered, ensure_ascii=False))
    ctx.index_path.write_text("\n".join(lines) + ("\n" if lines else ""))


def get_row(rows: list[dict], issue_id: int) -> dict:
    for r in rows:
        if r["id"] == issue_id:
            return r
    die(f"no issue with id {issue_id}")


def next_id(ctx: Ctx) -> int:
    ids = {r["id"] for r in load_index(ctx)}
    for name in status_names(ctx.cfg):
        d = ctx.dir / name
        if d.is_dir():
            for p in d.glob("*.md"):
                m = FILENAME_RE.match(p.name)
                if m:
                    ids.add(int(m.group(1)))
    return (max(ids) + 1) if ids else 1


